@inherits LayoutComponentBase
@inject Imbalances.Client.Services.ExplorerStateService ExplorerState

<MudThemeProvider Theme="_currentTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />


<MudLayout>
    <MudAppBar Elevation="0" Class="mud-elevation-0" Style="background-color: #002C54; color: #FFFFFF; border-bottom: 2px solid #555960;">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h5" Class="ml-3" Style="font-weight: 700; letter-spacing: 1.5px;">IMBALANCES <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled" Class="ml-2 mt-n1" Style="font-size: 0.65rem;">v1.1.9</MudChip></MudText>
        <MudSpacer />
        <MudText Typo="Typo.caption" Class="mr-4">© 2021-2026 <strong>Lantonium</strong>. Todos los derechos reservados.</MudText>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" Elevation="1" Anchor="Anchor.Left" Variant="@DrawerVariant.Responsive" Style="background-color: #FFFFFF; border-right: 1px solid #DAE0E6;">
        <MudDrawerHeader Class="pa-4">
            <MudText Typo="Typo.h6" Style="color: #002C54; font-weight: 700;">Menú Principal</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Outlined.Folder" Style="color: #002C54;">Explorador</MudNavLink>
            <MudNavLink Href="/analisis" Icon="@Icons.Material.Outlined.Analytics" Style="color: #002C54;">Análisis</MudNavLink>
            <MudNavLink Href="/informe" Icon="@Icons.Material.Outlined.Description" Style="color: #002C54;">Informe</MudNavLink>
            <MudNavLink Href="/config" Icon="@Icons.Material.Outlined.Settings" Style="color: #002C54;">Configuración</MudNavLink>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent Style="background-color: var(--app-bg);">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;

    private MudTheme _currentTheme = new MudTheme()
    {
        Typography = new Typography()
        {
            Default = new DefaultTypography()
            {
                FontFamily = new[] { "Tahoma", "Segoe UI", "Arial", "sans-serif" },
                FontWeight = "400"
            },
            H1 = new H1Typography() { FontFamily = new[] { "Tahoma", "Segoe UI", "Arial", "sans-serif" }, FontWeight = "700" },
            H2 = new H2Typography() { FontFamily = new[] { "Tahoma", "Segoe UI", "Arial", "sans-serif" }, FontWeight = "700" },
            H3 = new H3Typography() { FontFamily = new[] { "Tahoma", "Segoe UI", "Arial", "sans-serif" }, FontWeight = "700" },
            H4 = new H4Typography() { FontFamily = new[] { "Tahoma", "Segoe UI", "Arial", "sans-serif" }, FontWeight = "700" },
            H5 = new H5Typography() { FontFamily = new[] { "Tahoma", "Segoe UI", "Arial", "sans-serif" }, FontWeight = "700" },
            H6 = new H6Typography() { FontFamily = new[] { "Tahoma", "Segoe UI", "Arial", "sans-serif" }, FontWeight = "700" },
            Button = new ButtonTypography() { FontFamily = new[] { "Tahoma", "Segoe UI", "Arial", "sans-serif" }, FontWeight = "600", TextTransform = "none" }
        },
        PaletteLight = new PaletteLight()
        {
            Primary = "#002C54",
            Secondary = "#555960",
            Success = "#16A34A",
            Error = "#DC2626",
            Warning = "#F59E0B",
            Info = "#0EA5E9",
            Background = "#F3F5F7",
            Surface = "#FFFFFF",
            AppbarBackground = "#002C54",
            AppbarText = "#FFFFFF",
            DrawerBackground = "#FFFFFF",
            DrawerText = "#002C54",
            DrawerIcon = "#002C54",
            TextPrimary = "#002C54",
            TextSecondary = "#555960",
            ActionDefault = "#002C54",
            TableStriped = "#F8F9FA",
            TableHover = "#EEF2F6"
        }
    };

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void OnInputFileChanged(InputFileChangeEventArgs e)
    {
        ExplorerState.NotifyInputFileChanged(e);
    }
}
