{
  "layout": {
    "toolbarPosition": "top",
    "toolbarSticky": false,
    "toolbarBottomOffset": 16
  },
  "grid": {
    "scrollHorizontal": true,
    "resizableColumns": true,
    "minColumnWidth": 120
  },
  "card": {
    "collapsible": true,
    "defaultExpanded": true
  },
  "toolbar": {
    "showAdd": true,
    "showDelete": true,
    "showSave": true,
    "showImport": true,
    "showExport": true,
    "showLog": true,
    "actions": []
  },
  "pages": {
    "config": {
      "toolbar": {
        "actions": [
          { "id": "addEmpresa", "label": "Agregar empresa", "variant": "secondary" },
          { "id": "addCuenta", "label": "Agregar cuenta", "variant": "secondary" },
          { "id": "export", "label": "Descargar", "variant": "secondary" },
          { "id": "import", "label": "Subir", "variant": "secondary", "filePicker": true, "accept": ".xlsx", "multiple": false },
          { "id": "log", "label": "Log", "variant": "secondary" },
          { "id": "delete", "label": "Eliminar seleccionados", "variant": "danger" },
          { "id": "save", "label": "Guardar cambios", "variant": "primary" }
        ]
      }
    },
    "analisis": {
      "toolbar": {
        "actions": [
          { "id": "export", "label": "Exportar", "variant": "secondary" },
          { "id": "log", "label": "Log", "variant": "secondary" },
          { "id": "save", "label": "Guardar", "variant": "primary" }
        ]
      }
    }
  }
}
