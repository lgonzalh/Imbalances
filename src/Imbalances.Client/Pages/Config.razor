@page "/config"
@inject IConfigService ConfigService
@inject IJSRuntime JS
@inject Imbalances.Client.Services.UiFeedbackService Ui
@inject Imbalances.Client.Services.FirebaseMotorsService FirebaseMotors
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@inject Imbalances.Core.Services.IProgressService ProgressService
@inject NavigationManager Navigation
@using Imbalances.Core.Models
@using Imbalances.Core.Services
@using Microsoft.JSInterop
@using System.Text

<PageTitle>Imbalances - Configuración</PageTitle>

<AppPageContainer PageKey="config" Title="" Components="_snapshotComponents">
    <Toolbar>
        <AppToolbar PageKey="config" OnAction="HandleAction" OnFileAction="HandleFileAction" />
    </Toolbar>
    <ChildContent>
        <PasswordProtection Title="GRID 1: EMPRESAS" CorrectPassword="Juanes" OnUnlocked="@OnEmpresasUnlocked">
            <AppCard Title="GRID 1: EMPRESAS">
                <AppGrid TItem="EmpresaConfig" Items="@_config.Empresas" Selectable="true" SelectedIndexes="@_empresasSel" SelectedIndexesChanged="@OnEmpresasSelChanged">
                    <Columns>
                        <AppGridColumn TItem="EmpresaConfig" Title="Nombre carpeta">
                            <CellTemplate Context="item">
                                <input class="app-input" value="@item.NombreCarpeta" @oninput="(e) => item.NombreCarpeta = e.Value?.ToString() ?? string.Empty" />
                            </CellTemplate>
                        </AppGridColumn>
                        <AppGridColumn TItem="EmpresaConfig" Title="Nombre empresa">
                            <CellTemplate Context="item">
                                <input class="app-input" value="@item.NombreEmpresa" @oninput="(e) => item.NombreEmpresa = e.Value?.ToString() ?? string.Empty" />
                            </CellTemplate>
                        </AppGridColumn>
                                                <AppGridColumn TItem="EmpresaConfig" Title="ALIAS (OPCIONAL)">
                            <CellTemplate Context="item">
                                <input class="app-input" value="@item.Alias" @oninput="(e) => { item.Alias = e.Value?.ToString() ?? string.Empty; MarcarCambios(); }" />
                            </CellTemplate>
                        </AppGridColumn>
                        <AppGridColumn TItem="EmpresaConfig" Title="Company Code">
                            <CellTemplate Context="item">
                                <input class="app-input" value="@item.CompanyCode" @oninput="(e) => { item.CompanyCode = e.Value?.ToString() ?? string.Empty; MarcarCambios(); }" />
                            </CellTemplate>
                        </AppGridColumn>
                        <AppGridColumn TItem="EmpresaConfig" Title="Conc Op">
                            <CellTemplate Context="item">
                                <input class="app-input" value="@item.ConcOp" @oninput="(e) => { item.ConcOp = e.Value?.ToString() ?? string.Empty; MarcarCambios(); }" />
                            </CellTemplate>
                        </AppGridColumn>
                    </Columns>
                </AppGrid>
            </AppCard>
        </PasswordProtection>

        <AppCard Title="GRID 2: CUENTAS">
            <AppGrid TItem="CuentaConfig" Items="@_config.Cuentas" Selectable="true" SelectedIndexes="@_cuentasSel" SelectedIndexesChanged="@OnCuentasSelChanged">
                <Columns>
                    <AppGridColumn TItem="CuentaConfig" Title="Nombre cuenta">
                        <CellTemplate Context="item">
                            <input class="app-input" value="@item.NombreCuenta" @oninput="(e) => item.NombreCuenta = e.Value?.ToString() ?? string.Empty" />
                        </CellTemplate>
                    </AppGridColumn>
                    <AppGridColumn TItem="CuentaConfig" Title="Tipo (CxC|CxP)">
                        <CellTemplate Context="item">
                            <select class="app-select" value="@item.Tipo" @onchange="(e) => item.Tipo = e.Value?.ToString() ?? string.Empty">
                                <option value="CxC">CxC</option>
                                <option value="CxP">CxP</option>
                            </select>
                        </CellTemplate>
                    </AppGridColumn>
                    <AppGridColumn TItem="CuentaConfig" Title="Columna valor">
                        <CellTemplate Context="item">
                            <input class="app-input" value="@item.ColumnaValor" @oninput="(e) => item.ColumnaValor = e.Value?.ToString() ?? string.Empty" />
                        </CellTemplate>
                    </AppGridColumn>
                    <AppGridColumn TItem="CuentaConfig" Title="Columna nota">
                        <CellTemplate Context="item">
                            <input class="app-input" value="@item.ColumnaNota" @oninput="(e) => item.ColumnaNota = e.Value?.ToString() ?? string.Empty" />
                        </CellTemplate>
                    </AppGridColumn>
                </Columns>
            </AppGrid>
        </AppCard>
    </ChildContent>
</AppPageContainer>

@code {
    private ConfiguracionCore _config = new();
    private HashSet<int> _empresasSel = new();
    private HashSet<int> _cuentasSel = new();
    private readonly IReadOnlyList<string> _snapshotComponents = new[] { "AppPageContainer", "AppCard", "AppGrid", "AppToolbar" };
    #pragma warning disable CS0414 // kept for future internal nav validation
    private bool _hasUnsavedChanges;
    #pragma warning restore CS0414

    private Task OnEmpresasUnlocked() => Task.CompletedTask;

    private void MarcarCambios()
    {
        _hasUnsavedChanges = true;
        try { _ = JS.InvokeVoidAsync("eval", "window._imbalancesUnsavedChanges = true"); } catch { }
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        await SetupBeforeUnload();
        try
        {
            var functionsBaseUrl = Configuration["Firebase:FunctionsBaseUrl"] ?? string.Empty;
            if (!string.IsNullOrWhiteSpace(functionsBaseUrl))
            {
                var remoteConfig = await FirebaseMotors.ObtenerConfiguracionAsync(functionsBaseUrl);
                if (remoteConfig != null &&
                    (remoteConfig.Empresas.Count > 0 || remoteConfig.Cuentas.Count > 0))
                {
                    _config = remoteConfig;
                    await ConfigService.GuardarConfiguracionAsync(_config); // Sync local cache
                    _hasUnsavedChanges = false;
                    await JS.InvokeVoidAsync("eval", "window._imbalancesUnsavedChanges = false");
                    return;
                }
            }
        }
        catch (Exception ex)
        {
            Ui.ShowWarning($"No se pudo cargar desde Firebase: {ex.Message}. Cargando local.");
        }

        _config = await ConfigService.CargarConfiguracionAsync();
    }

    private async Task SetupBeforeUnload()
    {
        await JS.InvokeVoidAsync("eval", "window._imbalancesUnsavedChanges = false");
        await JS.InvokeVoidAsync("eval", "(function() { if (!window._imbalancesBeforeUnloadSet) { window._imbalancesBeforeUnloadSet = true; window.addEventListener(\"beforeunload\", function(e) { if (window._imbalancesUnsavedChanges) { e.preventDefault(); e.returnValue = \"\"; } }); } })();");
    }

    private Task OnEmpresasSelChanged(HashSet<int> indexes)
    {
        _empresasSel = indexes;
        return Task.CompletedTask;
    }

    private Task OnCuentasSelChanged(HashSet<int> indexes)
    {
        _cuentasSel = indexes;
        return Task.CompletedTask;
    }

    private async Task HandleAction(string id)
    {
        switch (id)
        {
            case "addEmpresa":
                AddEmpresa();
                break;
            case "addCuenta":
                AddCuenta();
                break;
            case "export":
                await ExportarConfig();
                break;
            case "log":
                await DescargarLog();
                break;
            case "delete":
                await EliminarSeleccionados();
                break;
            case "save":
                await Save();
                break;
        }
    }

    private async Task HandleFileAction(string id, InputFileChangeEventArgs e)
    {
        if (id == "import")
        {
            await ImportarConfig(e);
        }
    }

    private async Task Save()
    {
        var (errores, advertencias) = Validar(_config);
        if (errores.Count > 0)
        {
            Ui.ShowWarning($"Validación: se encontraron {errores.Count} error(es) bloqueantes.");
            foreach (var e in errores.Take(10))
            {
                Ui.ShowWarning(e);
            }
            return;
        }

        foreach (var w in advertencias.Take(10))
        {
            Ui.ShowWarning(w);
        }

        try
        {
            var functionsBaseUrl = Configuration["Firebase:FunctionsBaseUrl"] ?? string.Empty;
            if (!string.IsNullOrWhiteSpace(functionsBaseUrl))
            {
                await FirebaseMotors.GuardarConfiguracionAsync(functionsBaseUrl, _config);
                Ui.ShowSuccess("Configuración sincronizada con Firestore.");
            }
            else
            {
                Ui.ShowWarning("No hay FunctionsBaseUrl configurada. Solo se guardará localmente.");
            }
        }
        catch (Exception ex)
        {
            Ui.ShowError(ex, "Error sincronizando con Firestore.");
        }

        await ConfigService.GuardarConfiguracionAsync(_config);
        _hasUnsavedChanges = false;
        await JS.InvokeVoidAsync("eval", "window._imbalancesUnsavedChanges = false");
        Ui.ShowSuccess("Configuración guardada localmente.");
    }

    private void AddEmpresa() { _config.Empresas.Add(new EmpresaConfig()); MarcarCambios(); }
    private void AddCuenta() { _config.Cuentas.Add(new CuentaConfig()); MarcarCambios(); }
    private void AddNota() => _config.Notas.Add(new NotaConfig());
    private void AddEquivalencia() => _config.Equivalencias.Add(new CuentaEquivalencia());

    private async Task RemoveEmpresa(EmpresaConfig item)
    {
        var ok = await Ui.ConfirmAsync("Eliminar empresa", "¿Desea eliminar esta empresa de la configuración?");
        if (!ok) return;
        _config.Empresas.Remove(item);
    }

    private async Task RemoveCuenta(CuentaConfig item)
    {
        var ok = await Ui.ConfirmAsync("Eliminar cuenta", "¿Desea eliminar esta cuenta de la configuración?");
        if (!ok) return;
        _config.Cuentas.Remove(item);
    }

    private async Task RemoveNota(NotaConfig item)
    {
        var ok = await Ui.ConfirmAsync("Eliminar nota", "¿Desea eliminar esta nota de la configuración?");
        if (!ok) return;
        _config.Notas.Remove(item);
    }

    private async Task RemoveEquivalencia(CuentaEquivalencia item)
    {
        var ok = await Ui.ConfirmAsync("Eliminar equivalencia", "¿Desea eliminar esta equivalencia de la configuración?");
        if (!ok) return;
        _config.Equivalencias.Remove(item);
    }

    private void UpdateAliases(CuentaEquivalencia item, string value)
    {
        item.AliasTexto = (value ?? "").Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
    }

    private void UpdateNotasPermitidas(CuentaEquivalencia item, string value)
    {
        item.NotasPermitidas = (value ?? "").Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
    }

    private async Task ExportarConfig()
    {
        Console.WriteLine($"[Info] Exportando configuración");
        Console.WriteLine($"[Info] Empresas: {_config.Empresas.Count}");
        Console.WriteLine($"[Info] Cuentas: {_config.Cuentas.Count}");

        await JS.InvokeVoidAsync("excelInterop.descargarConfiguracionMotor", _config, "config_imbalances.xlsx");

        Console.WriteLine($"[Info] Hoja Empresas: {_config.Empresas.Count} filas");
        Console.WriteLine($"[Info] Hoja Cuentas: {_config.Cuentas.Count} filas");
        Console.WriteLine($"[Info] Workbook generado correctamente");

        Ui.ShowSuccess($"Descarga iniciada.");
    }

    private async Task DescargarLog()
    {
        var estado = ProgressService.ObtenerEstado();
        var logs = estado.Logs;

        if (!logs.Any())
        {
            Ui.ShowWarning("No hay log de procesamiento disponible. Ejecuta primero una extracción en el Explorador.");
            return;
        }

        var sb = new StringBuilder();
        sb.AppendLine("IMBALANCES - LOG DE PROCESAMIENTO");
        sb.AppendLine($"Generado: {DateTime.Now:yyyy-MM-dd HH:mm:ss}");
        sb.AppendLine($"Etapa actual: {estado.EtapaActual}");
        sb.AppendLine($"Archivos: {estado.CurrentStep}/{estado.TotalSteps}");
        sb.AppendLine(new string('-', 80));

        foreach (var log in logs)
        {
            sb.AppendLine($"[{log.Timestamp:yyyy-MM-dd HH:mm:ss}] [{log.Estado}] {log.Mensaje}");
        }

        var bytes = System.Text.Encoding.UTF8.GetBytes(sb.ToString());
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("eval", $"const a = document.createElement('a'); a.href = 'data:text/plain;base64,{base64}'; a.download = 'imbalances_log_{DateTime.Now:yyyyMMdd_HHmmss}.txt'; a.click();");
        Ui.ShowSuccess("Log descargado.");
    }

    private async Task EliminarSeleccionados()
    {
        var total = _empresasSel.Count + _cuentasSel.Count;
        if (total == 0)
        {
            Ui.ShowWarning("No hay filas seleccionadas.");
            return;
        }

        var ok = await Ui.ConfirmAsync("Eliminar seleccionados", $"¿Desea eliminar {total} elemento(s) seleccionado(s)?");
        if (!ok) return;

        foreach (var idx in _empresasSel.OrderByDescending(x => x).ToArray())
        {
            if (idx >= 0 && idx < _config.Empresas.Count) _config.Empresas.RemoveAt(idx);
        }

        foreach (var idx in _cuentasSel.OrderByDescending(x => x).ToArray())
        {
            if (idx >= 0 && idx < _config.Cuentas.Count) _config.Cuentas.RemoveAt(idx);
        }

        _empresasSel.Clear();
        _cuentasSel.Clear();
    }

    private async Task ImportarConfig(InputFileChangeEventArgs e)
    {
        try
        {
            if (!e.File.Name.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase))
            {
                Ui.ShowError("Archivo inválido: solo se permite .xlsx.");
                return;
            }

            await using var stream = e.File.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var streamRef = new DotNetStreamReference(stream);

            var result = await JS.InvokeAsync<ExcelConfigImportResult>("excelInterop.leerConfiguracionMotor", streamRef);
            if (!result.Ok || result.Config == null)
            {
                var errors = result.Errors ?? new List<string>();
                Ui.ShowError($"Importación cancelada: se encontraron {errors.Count} error(es).");
                foreach (var msg in errors.Take(20))
                {
                    Ui.ShowError(msg);
                }
                return;
            }

            _config.Empresas = result.Config.Empresas ?? new List<EmpresaConfig>();
            _config.Cuentas = result.Config.Cuentas ?? new List<CuentaConfig>();
            _empresasSel.Clear();
            _cuentasSel.Clear();

            await ConfigService.GuardarConfiguracionAsync(_config);
            _hasUnsavedChanges = false;
            await JS.InvokeVoidAsync("eval", "window._imbalancesUnsavedChanges = false");
            Ui.ShowSuccess("Configuración importada y guardada.");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Ui.ShowError(ex, "Error al importar.");
        }
    }

    private sealed class ExcelConfigImportResult
    {
        public bool Ok { get; set; }
        public List<string> Errors { get; set; } = new();
        public ConfiguracionCore? Config { get; set; }
    }

    private static (List<string> Errores, List<string> Advertencias) Validar(ConfiguracionCore config)
    {
        var errores = new List<string>();
        var advertencias = new List<string>();

        var companyCodeMap = new Dictionary<string, List<string>>(StringComparer.OrdinalIgnoreCase);
        var concOpMap = new Dictionary<string, List<string>>(StringComparer.OrdinalIgnoreCase);

        foreach (var e in config.Empresas)
        {
            var nombre = !string.IsNullOrWhiteSpace(e.NombreEmpresa)
                ? e.NombreEmpresa
                : !string.IsNullOrWhiteSpace(e.NombreCarpeta)
                    ? e.NombreCarpeta
                    : "(sin nombre)";

            if (string.IsNullOrWhiteSpace(e.NombreCarpeta))
                errores.Add($"Empresa '{nombre}': falta 'Nombre carpeta'.");

            if (!string.IsNullOrWhiteSpace(e.CompanyCode))
            {
                if (!companyCodeMap.ContainsKey(e.CompanyCode))
                    companyCodeMap[e.CompanyCode] = new List<string>();
                companyCodeMap[e.CompanyCode].Add(nombre);
            }

            if (!string.IsNullOrWhiteSpace(e.ConcOp))
            {
                if (!concOpMap.ContainsKey(e.ConcOp))
                    concOpMap[e.ConcOp] = new List<string>();
                concOpMap[e.ConcOp].Add(nombre);
            }

            if (string.IsNullOrWhiteSpace(e.CompanyCode))
                advertencias.Add($"Advertencia: '{nombre}' no tiene Company Code.");
            if (string.IsNullOrWhiteSpace(e.ConcOp))
                advertencias.Add($"Advertencia: '{nombre}' no tiene CONC_OP.");
            if (string.IsNullOrWhiteSpace(e.Alias))
                advertencias.Add($"Advertencia: '{nombre}' no tiene Alias.");
        }

        foreach (var kvp in companyCodeMap.Where(x => x.Value.Count > 1))
        {
            errores.Add($"Company Code '{kvp.Key}' está duplicado en: {string.Join(", ", kvp.Value)}.");
        }

        foreach (var kvp in concOpMap.Where(x => x.Value.Count > 1))
        {
            errores.Add($"CONC_OP '{kvp.Key}' está duplicado en: {string.Join(", ", kvp.Value)}.");
        }

        foreach (var c in config.Cuentas)
        {
            if (string.IsNullOrWhiteSpace(c.NombreCuenta)) errores.Add("Cuenta: falta 'Nombre cuenta'.");
            if (c.Tipo != "CxC" && c.Tipo != "CxP") errores.Add("Cuenta: 'Tipo' inválido (CxC|CxP).");
            if (string.IsNullOrWhiteSpace(c.ColumnaValor)) errores.Add("Cuenta: falta 'Columna valor'.");
            if (string.IsNullOrWhiteSpace(c.ColumnaNota)) errores.Add("Cuenta: falta 'Columna nota'.");
        }

        return (errores, advertencias);
    }

}
