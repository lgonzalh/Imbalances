@code {
    private List<IBrowserFile> _browserFiles = new();
    private List<FileTreeItem> TreeItems
    {
        get => ExplorerState.TreeItems;
        set => ExplorerState.TreeItems = value;
    }
    private string _searchString = "";
    private List<LogProceso> logsProcesamiento = new();
    private bool _scrollToBottom;
    private bool procesando = false;
    private List<FileJSData>? _pendingJsFiles;
    private Dictionary<string, IBrowserFile> _browserFileByPath = new(StringComparer.OrdinalIgnoreCase);
    private List<RegistroContable> _previewResultados = new();
    private string _functionsBaseUrl = string.Empty;
    private string _periodo = DateTime.Now.ToString("yyyy-MM");
    private decimal _tolerancia = 0;

    private DotNetObjectReference<Home>? _objRef;

    protected override async Task OnInitializedAsync()
    {
        _objRef = DotNetObjectReference.Create(this);
        _functionsBaseUrl = ExplorerState.FunctionsBaseUrl;
        if (string.IsNullOrWhiteSpace(_functionsBaseUrl))
        {
            _functionsBaseUrl = Configuration["Firebase:FunctionsBaseUrl"] ?? string.Empty;
        }

        if (!ExplorerState.TreeItems.Any() && !ExplorerState.Resultados.Any())
        {
            var savedState = await StatePersistence.CargarEstadoAsync();
            if (savedState != null && savedState.TreeItems.Any())
            {
                Console.WriteLine($"[Persistencia] Home: restaurando desde IndexedDB - TreeItems: {savedState.TreeItems.Count}, Resultados: {savedState.Resultados.Count}, Hallazgos: {savedState.Hallazgos.Count}, Reciprocidades: {savedState.Reciprocidades.Count}");
                ExplorerState.TreeItems = savedState.TreeItems;
                ExplorerState.Resultados = savedState.Resultados;
                ExplorerState.Hallazgos = savedState.Hallazgos;
                ExplorerState.DocumentosVerificados = savedState.DocumentosVerificados;
                ExplorerState.Reciprocidades = savedState.Reciprocidades;
                ExplorerState.EstadosHallazgos = savedState.EstadosHallazgos;
                ExplorerState.ArchivosProcesados = savedState.ArchivosProcesados;
                ExplorerState.ArchivosSeleccionados = savedState.ArchivosSeleccionados;
                logsProcesamiento = savedState.Logs ?? new();
            }
        }
        else
        {
            Console.WriteLine($"[Explorador] Estado vivo en memoria - TreeItems: {ExplorerState.TreeItems.Count}, Resultados: {ExplorerState.Resultados.Count}");
        }

        if (!logsProcesamiento.Any())
        {
            var progreso = ProgressService.ObtenerEstado();
            if (progreso.Logs.Any())
            {
                logsProcesamiento = progreso.Logs.ToList();
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("fileExplorer.getFiles", "folderInput", _objRef);
            await JS.InvokeVoidAsync("fileExplorer.getFiles", "filesInput", _objRef);
        }

        if (_scrollToBottom)
        {
            _scrollToBottom = false;
            await JS.InvokeVoidAsync("fileExplorer.scrollToBottom", "home-log-container");
        }
    }

    public void Dispose()
    {
        _objRef?.Dispose();
    }

    private void OnInputFileChanged(InputFileChangeEventArgs e)
    {
        _browserFiles = e.GetMultipleFiles(maximumFileCount: 5000)
                         .Where(f => f.Name.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase) || f.Name.EndsWith(".xls", StringComparison.OrdinalIgnoreCase))
                         .ToList();

        TryRebuildTree();
    }

    [JSInvokable]
    public void OnFilesSelectedJS(string inputId, List<FileJSData> files)
    {
        _pendingJsFiles = files;
        TryRebuildTree();
        StateHasChanged();
    }

    public class FileJSData
    {
        public string name { get; set; } = string.Empty;
        public string path { get; set; } = string.Empty;
        public long size { get; set; }
        public string lastModified { get; set; } = string.Empty;
    }

    private void TryRebuildTree()
    {
        if (_pendingJsFiles == null)
        {
            return;
        }

        if (_browserFiles.Count == 0)
        {
            return;
        }

        _browserFileByPath = BuildBrowserFileMap(_pendingJsFiles, _browserFiles);
        TreeItems = BuildTree(_pendingJsFiles, _browserFileByPath);
        // TreeItems already delegates to ExplorerState.TreeItems
        ExplorerState.BrowserFiles = _browserFiles;
    }

    private static Dictionary<string, IBrowserFile> BuildBrowserFileMap(List<FileJSData> jsFiles, List<IBrowserFile> browserFiles)
    {
        var map = new Dictionary<string, IBrowserFile>(StringComparer.OrdinalIgnoreCase);

        var index = browserFiles
            .GroupBy(b => (b.Name, b.Size, UtcMillis(b.LastModified)))
            .ToDictionary(g => g.Key, g => g.First());

        foreach (var jsFile in jsFiles)
        {
            var browserFile = TryFindBrowserFile(index, jsFile);
            if (browserFile == null) continue;
            if (string.IsNullOrWhiteSpace(jsFile.path)) continue;
            map[jsFile.path] = browserFile;
        }

        return map;
    }

    private static IBrowserFile? TryFindBrowserFile(
        IReadOnlyDictionary<(string Name, long Size, long LastModifiedUtcMillis), IBrowserFile> index,
        FileJSData jsFile)
    {
        var name = jsFile.name;
        var size = jsFile.size;

        var jsMillis = ParseUtcMillis(jsFile.lastModified);
        if (jsMillis.HasValue)
        {
            var key = (name, size, jsMillis.Value);
            if (index.TryGetValue(key, out var exact))
            {
                return exact;
            }

            foreach (var candidate in index)
            {
                if (!candidate.Key.Name.Equals(name, StringComparison.Ordinal) || candidate.Key.Size != size)
                {
                    continue;
                }

                if (Math.Abs(candidate.Key.LastModifiedUtcMillis - jsMillis.Value) <= 2000)
                {
                    return candidate.Value;
                }
            }
        }

        foreach (var candidate in index)
        {
            if (candidate.Key.Name.Equals(name, StringComparison.Ordinal) && candidate.Key.Size == size)
            {
                return candidate.Value;
            }
        }

        return null;
    }

    private static long UtcMillis(DateTimeOffset dto) => dto.ToUniversalTime().ToUnixTimeMilliseconds();

    private static long? ParseUtcMillis(string iso)
    {
        if (string.IsNullOrWhiteSpace(iso)) return null;
        return DateTimeOffset.TryParse(iso, out var dto) ? dto.ToUniversalTime().ToUnixTimeMilliseconds() : null;
    }

    private List<FileTreeItem> BuildTree(List<FileJSData> jsFiles, IReadOnlyDictionary<string, IBrowserFile> browserFileByPath)
    {
        var root = new FileTreeItem { IsFolder = true, Name = "root", Path = "", Level = -1 };

        foreach (var jsFile in jsFiles)
        {
            var parts = jsFile.path.Split('/');
            var current = root;
            string currentPath = "";

            for (int i = 0; i < parts.Length; i++)
            {
                var part = parts[i];
                currentPath += (string.IsNullOrEmpty(currentPath) ? "" : "/") + part;
                var isFile = i == parts.Length - 1;

                var child = current.Children.FirstOrDefault(c => c.Name == part);
                if (child == null)
                {
                    child = new FileTreeItem
                    {
                        Name = part,
                        Path = currentPath,
                        IsFolder = !isFile,
                        IsSelected = true,
                        Level = current.Level + 1
                    };
                    if (isFile)
                    {
                        if (browserFileByPath.TryGetValue(jsFile.path, out var browserFile))
                        {
                            child.BrowserFile = browserFile;
                        }
                    }
                    current.Children.Add(child);
                }
                current = child;
            }
        }
        return root.Children.ToList();
    }

    private List<FileTreeItem> GetFilteredItems()
    {
        if (string.IsNullOrWhiteSpace(_searchString))
        {
            SetAllVisible(TreeItems, true);
            return TreeItems;
        }

        ApplyFilter(TreeItems, _searchString);
        return TreeItems;
    }

    private void SetAllVisible(IEnumerable<FileTreeItem> items, bool visible)
    {
        foreach (var item in items)
        {
            item.Visible = visible;
            SetAllVisible(item.Children, visible);
        }
    }

    private bool ApplyFilter(IEnumerable<FileTreeItem> items, string filter, bool parentMatched = false)
    {
        bool anyVisible = false;
        foreach (var item in items)
        {
            bool matches = item.Name.Contains(filter, StringComparison.OrdinalIgnoreCase) || parentMatched;
            bool childrenVisible = ApplyFilter(item.Children, filter, matches);

            item.Visible = matches || childrenVisible;
            if (item.Visible)
            {
                anyVisible = true;
                if (childrenVisible && !string.IsNullOrEmpty(filter) && !parentMatched)
                    item.IsExpanded = true;
            }
        }
        return anyVisible;
    }

    private List<FileTreeItem> GetSelectedFiles()
    {
        // Forzar actualización de visibilidad según el filtro actual antes de procesar la selección
        if (string.IsNullOrWhiteSpace(_searchString))
        {
            SetAllVisible(TreeItems, true);
        }
        else
        {
            ApplyFilter(TreeItems, _searchString);
        }

        var selected = new List<FileTreeItem>();
        void Traverse(IEnumerable<FileTreeItem> items)
        {
            foreach (var item in items)
            {
                if (!item.Visible) continue;

                if (!item.IsFolder && item.IsSelected == true)
                {
                    selected.Add(item);
                }
                Traverse(item.Children);
            }
        }
        Traverse(TreeItems);
        return selected;
    }

    private void RemoveFile(FileTreeItem file)
    {
        file.IsSelected = false;
        StateHasChanged();
    }

    private async Task Cancelar()
    {
        TreeItems.Clear();
        _browserFiles.Clear();
        _pendingJsFiles = null;
        _browserFileByPath.Clear();
        _previewResultados.Clear();
        ExplorerState.Clear();
        logsProcesamiento.Clear();
        procesando = false;
        _searchString = "";

        await StatePersistence.LimpiarEstadoAsync();
        await JS.InvokeVoidAsync("fileExplorer.resetInput", "folderInput");
        await JS.InvokeVoidAsync("fileExplorer.resetInput", "filesInput");
        await InvokeAsync(StateHasChanged);
    }

    private async Task ProcesarSeleccion()
    {
        if (!MovimientosIntercompanyService.EsPeriodoValido(_periodo))
        {
            Ui.ShowInfo("Periodo inválido. Use formato YYYY-MM.");
            return;
        }

        var selectedFiles = GetSelectedFiles();
        var filesToProcess = selectedFiles.Where(f => f.BrowserFile != null).ToList();
        if (!filesToProcess.Any()) return;

        // Sincronizar con el estado global
        ExplorerState.Resultados.Clear();
        _previewResultados.Clear();
        ExplorerState.Hallazgos.Clear();
        ExplorerState.ArchivosSeleccionados = selectedFiles.Select(f => f.Path).ToList();

        logsProcesamiento.Clear();
        ExplorerState.IsProcessing = true;
        procesando = true;

        // Forzar actualización inmediata de la UI para mostrar barra de progreso
        await Task.Delay(1);
        StateHasChanged();

        // Suscribirse a los cambios del ProgressService
        ProgressService.OnChange += ActualizarLogs;

        ProgressService.Inicializar(filesToProcess.Count);
        ProgressService.Log("INICIO: Iniciando procesamiento de archivos seleccionados", "Info");

        try
        {
            var config = await ConfigService.CargarConfiguracionAsync();

            var registrosCrudos = new List<RegistroContable>();

            foreach (var fileItem in filesToProcess)
            {
                var file = fileItem.BrowserFile!;
                ProgressService.Log($"Iniciando extracción de: {file.Name}", "Info");

                try
                {
                    using var stream = file.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024);
                    using var memoryStream = new MemoryStream();
                    await stream.CopyToAsync(memoryStream);
                    memoryStream.Position = 0;

                    var res = await ExtractorEngine.ProcesarArchivoAsync(fileItem.Path, memoryStream, config, (msg) => ProgressService.Log(msg, "Info"));

                    registrosCrudos.AddRange(res);
                    _previewResultados.AddRange(res);

                    ProgressService.Log($"FIN: Extracción exitosa para {file.Name}", "Success");
                    ProgressService.Avanzar($"Completado: {file.Name}");
                }
                catch (Exception ex)
                {
                    ProgressService.Log($"ERROR en {file.Name}: {ex.Message}", "Error");
                }
            }

            ExplorerState.Resultados = _previewResultados;

            ProgressService.Log("NORMALIZACIÓN/AGRUPACIÓN: Preparando movimientos para Firestore.", "Info");
            var movimientosCrudos = registrosCrudos.Select(r => new Movimiento
            {
                EmpresaOrigen = r.Empresa,
                EmpresaContraparte = r.EmpresaContraparte,
                Tipo = r.Tipo,
                Cuenta = r.Cuenta,
                Valor = r.Valor,
                Nota = r.Nota,
                Periodo = _periodo,
            }).ToList();

            var movimientosAgrupados = MovimientosIntercompanyService.NormalizarYAgrupar(movimientosCrudos, _periodo);
            if (movimientosAgrupados.Any())
            {
                ExplorerState.Resultados = movimientosAgrupados.Select(m => new RegistroContable
                {
                    Empresa = m.EmpresaOrigen,
                    EmpresaContraparte = m.EmpresaContraparte,
                    Cuenta = m.Cuenta,
                    Categoria = "INTERCOMPANY",
                    Tipo = m.Tipo,
                    Nota = string.Empty,
                    Valor = m.Valor,
                    ArchivoOrigen = "(agrupado)",
                    HojaOrigen = string.Empty,
                    TextoOrigen = m.EmpresaContraparte
                }).ToList();
            }

            var functionsBaseUrl = (_functionsBaseUrl ?? string.Empty).Trim();
            ExplorerState.FunctionsBaseUrl = functionsBaseUrl;

            if (string.IsNullOrWhiteSpace(functionsBaseUrl))
            {
                Ui.ShowInfo("Configura FunctionsBaseUrl para subir a Firestore y generar cruces.");
                ProgressService.Log("CONFIG: FunctionsBaseUrl vacío. No se ejecuta Motor 2 ni Motor 3.", "Error");
                return;
            }

            if (!movimientosAgrupados.Any())
            {
                Ui.ShowInfo("No se generaron movimientos válidos para subir.");
                ProgressService.Log("NORMALIZACIÓN/AGRUPACIÓN: Sin movimientos válidos para enviar.", "Warning");
                return;
            }

            ProgressService.Log("MOTOR 2: Guardando movimientos en Firestore.", "Info");
            foreach (var grupoEmpresa in movimientosAgrupados.GroupBy(m => m.EmpresaOrigen))
            {
                var empresa = grupoEmpresa.Key;
                try
                {
                    var resp = await FirebaseMotors.GuardarMovimientosAsync(functionsBaseUrl, empresa, _periodo, grupoEmpresa.ToList());
                    ProgressService.Log($"MOTOR 2 OK ({empresa}): insertados={resp.Insertados}, duplicados={resp.Duplicados}, errores={resp.Errores}", resp.Errores > 0 ? "Warning" : "Success");
                }
                catch (Exception ex)
                {
                    ProgressService.Log($"MOTOR 2 ERROR ({empresa}): {ex.Message}", "Error");
                    Ui.ShowError(ex, "Motor 2 falló. No se ejecuta Motor 3.");
                    return;
                }
            }

            ProgressService.Log("MOTOR 3: Ejecutando cruce intercompany en backend.", "Info");
            try
            {
                var cruce = await FirebaseMotors.CruzarAsync(functionsBaseUrl, _periodo, _tolerancia);
                ProgressService.Log($"MOTOR 3 OK: ok={cruce.Ok}, descuadre={cruce.Descuadre}, pares={cruce.ParesEvaluados}", cruce.Descuadre > 0 ? "Warning" : "Success");
                if (cruce.Descuadre > 0) Ui.ShowInfo($"Cruce generado. OK={cruce.Ok}, DESCUADRE={cruce.Descuadre}.");
                else Ui.ShowSuccess($"Cruce generado. OK={cruce.Ok}.");
            }
            catch (Exception ex)
            {
                ProgressService.Log($"MOTOR 3 ERROR: {ex.Message}", "Error");
                Ui.ShowError(ex, "Motor 3 falló.");
            }

            ProgressService.Log("FIN GLOBAL: Proceso finalizado correctamente.", "Success");

            // Persistir el estado completo para que se mantenga al navegar
            Console.WriteLine($"[Persistencia] Home: guardando estado - TreeItems: {ExplorerState.TreeItems.Count}, Resultados: {ExplorerState.Resultados.Count}, Hallazgos: {ExplorerState.Hallazgos.Count}, Reciprocidades: {ExplorerState.Reciprocidades.Count}");
            await StatePersistence.GuardarEstadoAsync(new Imbalances.Client.Services.PersistenceState
            {
                FunctionsBaseUrl = ExplorerState.FunctionsBaseUrl,
                Resultados = ExplorerState.Resultados,
                Hallazgos = ExplorerState.Hallazgos,
                DocumentosVerificados = ExplorerState.DocumentosVerificados,
                Reciprocidades = ExplorerState.Reciprocidades,
                EstadosHallazgos = ExplorerState.EstadosHallazgos,
                ArchivosProcesados = ExplorerState.ArchivosProcesados,
                ArchivosSeleccionados = ExplorerState.ArchivosSeleccionados,
                TreeItems = ExplorerState.TreeItems,
                Logs = logsProcesamiento
            });
        }
        catch (Exception globalEx)
        {
            ProgressService.Log($"ERROR GLOBAL: Fallo inesperado en el procesamiento. {globalEx.Message}", "Error");
        }
        finally
        {
            ProgressService.OnChange -= ActualizarLogs;
            ExplorerState.IsProcessing = false;
            procesando = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ActualizarLogs()
    {
        var estado = ProgressService.ObtenerEstado();
        logsProcesamiento = estado.Logs.ToList();
        _scrollToBottom = true;
        InvokeAsync(StateHasChanged);
    }

    private string GetLogCssClass(string estado)
    {
        return estado.ToLower() switch
        {
            "info" => "log-info",
            "success" => "log-success",
            "error" => "log-error",
            "warning" => "log-warning",
            _ => "log-info"
        };
    }

    private async Task ExportarLog()
    {
        if (!logsProcesamiento.Any()) return;

        var estado = ProgressService.ObtenerEstado();
        var fechaGeneracion = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss");

        var contenido = new StringBuilder();
        contenido.AppendLine("IMBALANCES - LOG DE PROCESAMIENTO");
        contenido.AppendLine($"Generado: {fechaGeneracion}");
        contenido.AppendLine($"Etapa actual: {estado.EtapaActual}");
        contenido.AppendLine($"Archivo de Excel: {estado.CurrentStep}/{estado.TotalSteps}");
        contenido.AppendLine(new string('-', 80));

        foreach (var log in logsProcesamiento)
        {
            contenido.AppendLine($"[{log.Timestamp:yyyy-MM-dd HH:mm:ss}] [{log.Estado}] {log.Mensaje}");
        }

        var bytes = Encoding.UTF8.GetBytes(contenido.ToString());
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("eval", $"const a = document.createElement('a'); a.href = 'data:text/plain;base64,{base64}'; a.download = 'imbalances_log_{DateTime.Now:yyyyMMdd_HHmmss}.txt'; a.click();");
    }

    private double GetProgressValue()
    {
        var estado = ProgressService.ObtenerEstado();
        if (estado.TotalSteps == 0) return 0;
        return (double)estado.CurrentStep / estado.TotalSteps * 100;
    }

    private string GetProgressText()
    {
        var estado = ProgressService.ObtenerEstado();
        if (estado.TotalSteps == 0) return "Inicializando...";
        return $"Archivo {Math.Max(1, estado.CurrentStep)} de {estado.TotalSteps} - {estado.EtapaActual}";
    }
}


