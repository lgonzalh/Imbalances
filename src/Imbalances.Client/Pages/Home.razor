@code {
    private List<IBrowserFile> _browserFiles = new();
    private List<TreeItemData> TreeItems { get; set; } = new();
    private string _searchString = "";
    private List<LogProceso> logsProcesamiento = new();
    private bool procesando = false;

    public class TreeItemData : ITreeItemData<TreeItemData>
    {
        public string Name { get; set; } = string.Empty;
        public string Path { get; set; } = string.Empty;
        public bool IsFolder { get; set; }
        public int Level { get; set; }
        public IBrowserFile? BrowserFile { get; set; }
        
        private bool? _isSelected = false;
        public bool? IsSelected 
        { 
            get 
            {
                if (!IsFolder) return _isSelected;
                if (!Children.Any()) return _isSelected;
                
                bool allSelected = Children.All(c => c.IsSelected == true);
                bool noneSelected = Children.All(c => c.IsSelected == false);
                
                if (allSelected) return true;
                if (noneSelected) return false;
                return null; // Indeterminate
            }
            set 
            {
                _isSelected = value ?? false;
                if (IsFolder)
                {
                    foreach (var child in Children)
                    {
                        child.IsSelected = value;
                    }
                }
            } 
        }
        public bool IsExpanded { get; set; } = true;
        public List<TreeItemData> Children { get; set; } = new();

        public string? Text { get => Name; set => Name = value ?? ""; }
        public string? Icon { get; set; }
        public string? IconColor { get; set; }
        public string? SelectedIcon { get; set; }
        public bool Expanded { get => IsExpanded; set => IsExpanded = value; }
        public bool Selected { get => IsSelected == true; set => IsSelected = value; }
        public bool Disabled { get; set; }
        public bool? Loading { get; set; }
        public bool Visible { get; set; } = true;
        public bool HasChildren => Children.Any();
        public bool Expandable { get; set; } = true;
        IReadOnlyCollection<ITreeItemData<TreeItemData>>? ITreeItemData<TreeItemData>.Children { get => Children; set { } }
        public IReadOnlyCollection<TreeItemData>? Items => Children;
        public TreeItemData? Value { get => this; set { } }
    }

    private DotNetObjectReference<Home>? _objRef;

    protected override void OnInitialized()
    {
        _objRef = DotNetObjectReference.Create(this);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("fileExplorer.getFiles", "folderInput", _objRef);
            await JS.InvokeVoidAsync("fileExplorer.getFiles", "filesInput", _objRef);
        }
    }

    public void Dispose()
    {
        _objRef?.Dispose();
    }

    private void OnInputFileChanged(InputFileChangeEventArgs e)
    {
        _browserFiles = e.GetMultipleFiles(maximumFileCount: 5000)
                         .Where(f => f.Name.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase) || f.Name.EndsWith(".xls", StringComparison.OrdinalIgnoreCase))
                         .ToList();
    }

    [JSInvokable]
    public void OnFilesSelectedJS(List<FileJSData> files)
    {
        TreeItems = BuildTree(files);
        StateHasChanged();
    }

    public class FileJSData
    {
        public string name { get; set; } = string.Empty;
        public string path { get; set; } = string.Empty;
        public long size { get; set; }
    }

    private List<TreeItemData> BuildTree(List<FileJSData> jsFiles)
    {
        var root = new TreeItemData { IsFolder = true, Name = "root", Path = "", Level = -1 };

        foreach (var jsFile in jsFiles)
        {
            var parts = jsFile.path.Split('/');
            var current = root;
            string currentPath = "";

            for (int i = 0; i < parts.Length; i++)
            {
                var part = parts[i];
                currentPath += (string.IsNullOrEmpty(currentPath) ? "" : "/") + part;
                var isFile = i == parts.Length - 1;

                var child = current.Children.FirstOrDefault(c => c.Name == part);
                if (child == null)
                {
                    child = new TreeItemData
                    {
                        Name = part,
                        Path = currentPath,
                        IsFolder = !isFile,
                        IsSelected = true,
                        Level = current.Level + 1
                    };
                    if (isFile)
                    {
                        child.BrowserFile = _browserFiles.FirstOrDefault(b => b.Name == jsFile.name && b.Size == jsFile.size);
                    }
                    current.Children.Add(child);
                }
                current = child;
            }
        }
        return root.Children.ToList();
    }

    private List<TreeItemData> GetFilteredItems()
    {
        if (string.IsNullOrWhiteSpace(_searchString))
        {
            SetAllVisible(TreeItems, true);
            return TreeItems;
        }
        
        ApplyFilter(TreeItems, _searchString);
        return TreeItems;
    }

    private void SetAllVisible(IEnumerable<TreeItemData> items, bool visible)
    {
        foreach (var item in items)
        {
            item.Visible = visible;
            SetAllVisible(item.Children, visible);
        }
    }

    private bool ApplyFilter(IEnumerable<TreeItemData> items, string filter, bool parentMatched = false)
    {
        bool anyVisible = false;
        foreach (var item in items)
        {
            bool matches = item.Name.Contains(filter, StringComparison.OrdinalIgnoreCase) || parentMatched;
            bool childrenVisible = ApplyFilter(item.Children, filter, matches);
            
            item.Visible = matches || childrenVisible;
            if (item.Visible)
            {
                anyVisible = true;
                if (childrenVisible && !string.IsNullOrEmpty(filter) && !parentMatched) 
                    item.IsExpanded = true;
            }
        }
        return anyVisible;
    }

    private List<TreeItemData> GetSelectedFiles()
    {
        // Forzar actualización de visibilidad según el filtro actual antes de procesar la selección
        if (string.IsNullOrWhiteSpace(_searchString))
        {
            SetAllVisible(TreeItems, true);
        }
        else
        {
            ApplyFilter(TreeItems, _searchString);
        }

        var selected = new List<TreeItemData>();
        void Traverse(IEnumerable<TreeItemData> items)
        {
            foreach (var item in items)
            {
                if (!item.Visible) continue;

                if (!item.IsFolder && item.IsSelected == true)
                {
                    selected.Add(item);
                }
                Traverse(item.Children);
            }
        }
        Traverse(TreeItems);
        return selected;
    }

    private void RemoveFile(TreeItemData file)
    {
        file.IsSelected = false;
        StateHasChanged();
    }

    private void Cancelar()
    {
        TreeItems.Clear();
        _browserFiles.Clear();
        ExplorerState.Resultados.Clear();
    }

    private async Task ProcesarSeleccion()
    {
        var selectedFiles = GetSelectedFiles();
        var filesToProcess = selectedFiles.Where(f => f.BrowserFile != null).ToList();
        if (!filesToProcess.Any()) return;

        // Sincronizar con el estado global
        ExplorerState.Resultados.Clear();
        ExplorerState.Hallazgos.Clear();
        ExplorerState.ArchivosSeleccionados = selectedFiles.Select(f => f.Path).ToList();
        
        logsProcesamiento.Clear();
        procesando = true;
        
        // Forzar actualización inmediata de la UI para mostrar barra de progreso
        await Task.Delay(1); 
        StateHasChanged();
        
        // Suscribirse a los cambios del ProgressService
        ProgressService.OnChange += ActualizarLogs;
        
        ProgressService.Inicializar(filesToProcess.Count);
        ProgressService.Log("INICIO: Iniciando procesamiento de archivos seleccionados", "Info");
        
        try 
        {
            var config = await ConfigService.CargarConfiguracionAsync();

            foreach (var fileItem in filesToProcess)
            {
                var file = fileItem.BrowserFile!;
                ProgressService.Log($"Iniciando extracción de: {file.Name}", "Info");
                
                try
                {
                    using var stream = file.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024);
                    using var memoryStream = new MemoryStream();
                    await stream.CopyToAsync(memoryStream);
                    memoryStream.Position = 0;

                    var res = await ExtractorEngine.ProcesarArchivoAsync(fileItem.Path, memoryStream, config, (msg) => ProgressService.Log(msg, "Info"));
                    
                    // Guardar en el estado global para que otras páginas lo vean
                    ExplorerState.Resultados.AddRange(res);
                    
                    ProgressService.Log($"FIN: Extracción exitosa para {file.Name}", "Success");
                    ProgressService.Avanzar($"Completado: {file.Name}");
                }
                catch (Exception ex)
                {
                    ProgressService.Log($"ERROR en {file.Name}: {ex.Message}", "Error");
                }
            }

            ProgressService.Log("FIN GLOBAL: Proceso finalizado correctamente.", "Success");
            
            // Persistir el estado para que se mantenga al navegar
            await StatePersistence.GuardarEstadoAsync(new Imbalances.Client.Services.PersistenceState
            {
                Resultados = ExplorerState.Resultados,
                ArchivosSeleccionados = ExplorerState.ArchivosSeleccionados,
                ArchivosProcesados = ExplorerState.ArchivosProcesados
            });
        }
        catch (Exception globalEx)
        {
            ProgressService.Log($"ERROR GLOBAL: Fallo inesperado en el procesamiento. {globalEx.Message}", "Error");
        }
        finally
        {
            ProgressService.OnChange -= ActualizarLogs;
            procesando = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ActualizarLogs()
    {
        var estado = ProgressService.ObtenerEstado();
        logsProcesamiento = estado.Logs.ToList();
        InvokeAsync(StateHasChanged);
    }

    private string GetLogCssClass(string estado)
    {
        return estado.ToLower() switch
        {
            "info" => "log-info",
            "success" => "log-success",
            "error" => "log-error",
            "warning" => "log-warning",
            _ => "log-info"
        };
    }

    private async Task ExportarLog()
    {
        if (!logsProcesamiento.Any()) return;

        var estado = ProgressService.ObtenerEstado();
        var fechaGeneracion = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss");
        
        var contenido = new StringBuilder();
        contenido.AppendLine("IMBALANCES - LOG DE PROCESAMIENTO");
        contenido.AppendLine($"Generado: {fechaGeneracion}");
        contenido.AppendLine($"Etapa actual: {estado.EtapaActual}");
        contenido.AppendLine($"Archivo de Excel: {estado.CurrentStep}/{estado.TotalSteps}");
        contenido.AppendLine(new string('-', 80));

        foreach (var log in logsProcesamiento)
        {
            contenido.AppendLine($"[{log.Timestamp:yyyy-MM-dd HH:mm:ss}] [{log.Estado}] {log.Mensaje}");
        }

        var bytes = Encoding.UTF8.GetBytes(contenido.ToString());
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("eval", $"const a = document.createElement('a'); a.href = 'data:text/plain;base64,{base64}'; a.download = 'imbalances_log_{DateTime.Now:yyyyMMdd_HHmmss}.txt'; a.click();");
    }

    private double GetProgressValue()
    {
        var estado = ProgressService.ObtenerEstado();
        if (estado.TotalSteps == 0) return 0;
        return (double)estado.CurrentStep / estado.TotalSteps * 100;
    }

    private string GetProgressText()
    {
        var estado = ProgressService.ObtenerEstado();
        if (estado.TotalSteps == 0) return "Inicializando...";
        return $"Archivo {estado.CurrentStep} de {estado.TotalSteps} - {estado.EtapaActual}";
    }
}
