@code {
    private List<IBrowserFile> _browserFiles = new();
    private List<TreeItemData> TreeItems { get; set; } = new();

    public class TreeItemData : ITreeItemData<TreeItemData>
    {
        public string Name { get; set; } = string.Empty;
        public string Path { get; set; } = string.Empty;
        public bool IsFolder { get; set; }
        public IBrowserFile? BrowserFile { get; set; }
        public bool IsSelected { get; set; }
        public bool IsExpanded { get; set; } = true;
        public List<TreeItemData> Children { get; set; } = new();

        public string? Text { get => Name; set => Name = value ?? ""; }
        public string? Icon { get => IsFolder ? Icons.Material.Filled.Folder : Icons.Custom.FileFormats.FileExcel; set { } }
        public string? IconColor { get; set; }
        public string? SelectedIcon { get; set; }
        public bool Expanded { get => IsExpanded; set => IsExpanded = value; }
        public bool Selected { get => IsSelected; set => IsSelected = value; }
        public bool Disabled { get; set; }
        public bool? Loading { get; set; }
        public bool Visible { get; set; } = true;
        public bool Expandable { get => true; set { } }
        public bool HasChildren => Children.Any();
        IReadOnlyCollection<ITreeItemData<TreeItemData>>? ITreeItemData<TreeItemData>.Children { get => Children; set { } }
        public IReadOnlyCollection<TreeItemData>? Items => Children;
        public TreeItemData? Value { get => this; set { } }
    }

    private DotNetObjectReference<Home>? _objRef;

    protected override void OnInitialized()
    {
        _objRef = DotNetObjectReference.Create(this);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("fileExplorer.getFiles", "folderInput", _objRef);
            await JS.InvokeVoidAsync("fileExplorer.getFiles", "filesInput", _objRef);
        }
    }

    public void Dispose()
    {
        _objRef?.Dispose();
    }

    private void OnInputFileChanged(InputFileChangeEventArgs e)
    {
        _browserFiles = e.GetMultipleFiles(maximumFileCount: 5000)
                         .Where(f => f.Name.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase) || f.Name.EndsWith(".xls", StringComparison.OrdinalIgnoreCase))
                         .ToList();
    }

    [JSInvokable]
    public void OnFilesSelectedJS(List<FileJSData> files)
    {
        TreeItems = BuildTree(files);
        StateHasChanged();
    }

    public class FileJSData
    {
        public string name { get; set; } = string.Empty;
        public string path { get; set; } = string.Empty;
        public long size { get; set; }
    }

    private List<TreeItemData> BuildTree(List<FileJSData> jsFiles)
    {
        var root = new TreeItemData { IsFolder = true, Name = "root", Path = "" };

        foreach (var jsFile in jsFiles)
        {
            var parts = jsFile.path.Split('/');
            var current = root;
            string currentPath = "";

            for (int i = 0; i < parts.Length; i++)
            {
                var part = parts[i];
                currentPath += (string.IsNullOrEmpty(currentPath) ? "" : "/") + part;
                var isFile = i == parts.Length - 1;

                var child = current.Children.FirstOrDefault(c => c.Name == part);
                if (child == null)
                {
                    child = new TreeItemData
                    {
                        Name = part,
                        Path = currentPath,
                        IsFolder = !isFile,
                        IsSelected = true
                    };
                    if (isFile)
                    {
                        child.BrowserFile = _browserFiles.FirstOrDefault(b => b.Name == jsFile.name && b.Size == jsFile.size);
                    }
                    current.Children.Add(child);
                }
                current = child;
            }
        }
        return root.Children.ToList();
    }

    private List<TreeItemData> GetSelectedFiles()
    {
        var selected = new List<TreeItemData>();
        void Traverse(IEnumerable<TreeItemData> items)
        {
            foreach (var item in items)
            {
                if (!item.IsFolder && item.IsSelected)
                {
                    selected.Add(item);
                }
                Traverse(item.Children);
            }
        }
        Traverse(TreeItems);
        return selected;
    }

    private void RemoveFile(TreeItemData file)
    {
        file.IsSelected = false;
        StateHasChanged();
    }

    private void Cancelar()
    {
        TreeItems.Clear();
        _browserFiles.Clear();
        resultados.Clear();
    }

    private List<RegistroContable> resultados = new();

    private async Task ProcesarSeleccion()
    {
        var filesToProcess = GetSelectedFiles().Where(f => f.BrowserFile != null).ToList();
        if (!filesToProcess.Any()) return;

        resultados.Clear();
        ProgressService.Inicializar(filesToProcess.Count);
        
        var config = await ConfigService.CargarConfiguracionAsync();

        foreach (var fileItem in filesToProcess)
        {
            var file = fileItem.BrowserFile!;
            ProgressService.Log($"Procesando {file.Name}", "Info");
            
            try
            {
                using var stream = file.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024);
                using var memoryStream = new MemoryStream();
                await stream.CopyToAsync(memoryStream);
                memoryStream.Position = 0;

                var res = await ExtractorEngine.ProcesarArchivoAsync(fileItem.Path, memoryStream, config);
                resultados.AddRange(res);
                
                ProgressService.Avanzar($"Completado: {file.Name}");
            }
            catch (Exception ex)
            {
                ProgressService.Log($"Error en {file.Name}: {ex.Message}", "Error");
            }
        }

        ProgressService.Log("Proceso finalizado.", "Success");
        StateHasChanged();
    }
}
