@page "/"
@inject IProgressService ProgressService
@inject IConfigService ConfigService
@inject IExtractorEngine ExtractorEngine
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Imbalances - Explorador</PageTitle>

<div class="explorer-container">
    <div class="explorer-layout">
        <!-- Panel Izquierdo: Explorador -->
        <div class="panel left-panel">
            <div class="panel-header">
                <MudText Typo="Typo.h6">Explorador de archivos</MudText>
            </div>
            <div class="panel-content scrollable">
                <InputFile id="folderInput" multiple OnChange="OnInputFileChanged" style="display: none;" accept=".xlsx,.xls" webkitdirectory directory />
                <InputFile id="filesInput" multiple OnChange="OnInputFileChanged" style="display: none;" accept=".xlsx,.xls" />
                
                @if (!TreeItems.Any())
                {
                    <div class="d-flex flex-column align-center justify-center h-100 pa-8">
                        <MudButton HtmlTag="label" for="folderInput" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.FolderOpen" Class="mb-4">
                            Cargar Carpeta
                        </MudButton>
                        <MudButton HtmlTag="label" for="filesInput" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.FileUpload">
                            Cargar Archivos
                        </MudButton>
                    </div>
                }
                else
                {
                    <MudTreeView T="TreeItemData" Items="TreeItems" Hover="true" Dense="true" Class="custom-tree">
                        <ItemTemplate Context="item">
                            <MudTreeViewItem T="TreeItemData" @bind-Expanded="@item.Expanded" Items="@item.Children" Text="@item.Text" Icon="@item.Icon" Class="tree-item">
                                <Content>
                                    <div class="tree-item-content">
                                        <MudCheckBox @bind-Value="item.Value.IsSelected" Color="Color.Primary" Dense="true" Class="tree-checkbox" />
                                        <MudIcon Icon="@item.Icon" Class="tree-icon" />
                                        <MudText Typo="Typo.body2" Class="tree-text">@item.Text</MudText>
                                    </div>
                                </Content>
                            </MudTreeViewItem>
                        </ItemTemplate>
                    </MudTreeView>
                }
            </div>
        </div>

        <!-- Panel Derecho: Archivos Seleccionados -->
        <div class="panel right-panel">
            <div class="panel-header d-flex justify-space-between align-center">
                <MudText Typo="Typo.h6">Archivos seleccionados</MudText>
                <div class="counter-badge">@GetSelectedFiles().Count archivos</div>
            </div>
            <div class="panel-content scrollable pa-2">
                @foreach (var file in GetSelectedFiles())
                {
                    <div class="file-card">
                        <div class="file-card-info">
                            <MudIcon Icon="@Icons.Custom.FileFormats.FileExcel" Color="Color.Success" Class="file-card-icon" />
                            <div class="file-card-text">
                                <MudText Typo="Typo.body2" Class="file-card-name">@file.Name</MudText>
                                <MudText Typo="Typo.caption" Class="file-card-path">@file.Path</MudText>
                            </div>
                        </div>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Default" Class="file-card-close" OnClick="@(() => RemoveFile(file))" />
                    </div>
                }
            </div>
            <div class="panel-footer">
                <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancelar" Class="footer-btn">Cancelar</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ProcesarSeleccion" Disabled="@(!GetSelectedFiles().Any())" Class="footer-btn confirm-btn">
                    Confirmar selección
                    <MudIcon Icon="@Icons.Material.Filled.ArrowOutward" Size="Size.Small" Class="ml-1" />
                </MudButton>
            </div>
        </div>
    </div>

    @if (resultados.Any())
    {
        <MudItem xs="12">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Resultados de la extracción</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudDataGrid Items="@resultados" Dense="true" Hover="true" Striped="true" FixedHeader="true" Height="400px" Class="results-grid">
                        <Columns>
                            <PropertyColumn Property="x => x.Empresa" Title="Empresa" />
                            <PropertyColumn Property="x => x.Cuenta" Title="Cuenta" />
                            <PropertyColumn Property="x => x.Categoria" Title="Categoría" />
                            <PropertyColumn Property="x => x.Tipo" Title="Tipo" />
                            <PropertyColumn Property="x => x.Nota" Title="Nota" />
                            <PropertyColumn Property="x => x.Valor" Title="Valor" Format="N2" />
                        </Columns>
                    </MudDataGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</div>

