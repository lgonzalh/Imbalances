@page "/"
@inject IProgressService ProgressService
@inject IConfigService ConfigService
@inject IExtractorEngine ExtractorEngine
@inject IJSRuntime JS
@inject Imbalances.Client.Services.ExplorerStateService ExplorerState
@inject Imbalances.Client.Services.IStatePersistenceService StatePersistence
@using System.Text
@using Imbalances.Core.Models
@using Imbalances.Client.Services
@implements IDisposable

<PageTitle>Imbalances - Explorador de Datos</PageTitle>

<div class="explorer-container">
    <div class="explorer-layout">
        <!-- Panel Izquierdo: Explorador -->
        <div class="panel left-panel">
            <div class="panel-header explorer-header-grid">
                <MudText Typo="Typo.h6" Class="brand-title">EXPLORADOR DE ARCHIVOS</MudText>
                <div class="filter-container">
                    <MudTextField @bind-Value="_searchString" 
                                  Placeholder="Filtro" 
                                  Adornment="Adornment.End" 
                                  AdornmentIcon="@Icons.Material.Filled.FilterList" 
                                  IconSize="Size.Small"
                                  Variant="Variant.Outlined" 
                                  Margin="Margin.Dense" 
                                  Class="filter-input"
                                  Immediate="true"
                                  Clearable="true" />
                </div>
            </div>
            <div class="panel-content scrollable">
                <InputFile id="folderInput" multiple OnChange="OnInputFileChanged" style="display: none;" accept=".xlsx,.xls" webkitdirectory directory />
                <InputFile id="filesInput" multiple OnChange="OnInputFileChanged" style="display: none;" accept=".xlsx,.xls" />
                
                @if (!TreeItems.Any())
                {
                    <div class="d-flex flex-column align-center justify-center h-100 pa-10">
                        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-4 mb-6 text-center">Seleccione la carpeta o archivos de cierre contable para iniciar el análisis.</MudText>
                        <div class="d-flex gap-4">
                            <MudButton HtmlTag="label" for="folderInput" Variant="Variant.Filled" Color="Color.Primary" Class="px-6 py-2">
                                Cargar Carpeta
                            </MudButton>
                            <MudButton HtmlTag="label" for="filesInput" Variant="Variant.Outlined" Color="Color.Primary" Class="px-6 py-2">
                                Cargar Archivos
                            </MudButton>
                        </div>
                    </div>
                }
                else
                {
                            <MudTreeView T="TreeItemData" Items="@(GetFilteredItems().Where(i => i.Visible).Cast<ITreeItemData<TreeItemData>>().ToList())" Hover="true" Dense="true" Class="custom-tree" ExpandOnDoubleClick="true">
                        <ItemTemplate Context="item">
                            @{ var data = item.Value; }
                            <MudTreeViewItem T="TreeItemData" @bind-Expanded="data.Expanded" Items="@(data.Children.Where(c => c.Visible).Cast<ITreeItemData<TreeItemData>>().ToList())" Class="tree-item">
                                <Content>
                                    <div class="tree-item-content" style="@($"margin-left: {data.Level * 16}px;")">
                                        <div class="tree-toggle-container">
                                            @if (data.HasChildren)
                                            {
                                                <MudIconButton Icon="@(data.Expanded ? Icons.Material.Filled.ArrowDropDown : Icons.Material.Filled.ArrowRight)" 
                                                               Size="Size.Small" 
                                                               OnClick="@(() => data.Expanded = !data.Expanded)" 
                                                               Class="tree-arrow-btn" />
                                            }
                                        </div>

                                        @if (data.IsFolder)
                                        {
                                            <MudIcon Icon="@(data.Expanded ? Icons.Material.Filled.FolderOpen : Icons.Material.Filled.Folder)" 
                                                     Size="Size.Small" Color="Color.Default" Class="mr-2" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Custom.FileFormats.FileExcel" Size="Size.Small" Color="Color.Success" Class="mr-2" />
                                        }

                                        <MudCheckBox T="bool?" Value="data.IsSelected" ValueChanged="@((v) => data.IsSelected = v)" 
                                                     Color="Color.Primary" Dense="true" Class="tree-checkbox" TriState="false" />

                                        <MudText Typo="Typo.body2" Class="tree-text">@data.Text</MudText>
                                    </div>
                                </Content>
                            </MudTreeViewItem>
                        </ItemTemplate>
                    </MudTreeView>
                }
            </div>
        </div>

        <!-- Panel Derecho: Archivos Seleccionados -->
        <div class="panel right-panel">
            <div class="panel-header d-flex justify-space-between align-center">
                <MudText Typo="Typo.h6" Class="brand-title">ORDEN DE PROCESAMIENTO</MudText>
                <MudChip T="string" Color="Color.Dark" Variant="Variant.Filled" Size="Size.Small" Class="selected-count-chip">@GetSelectedFiles().Count seleccionados</MudChip>
            </div>
            <div class="panel-content scrollable pa-4">
                @if (!GetSelectedFiles().Any())
                {
                    <div class="d-flex align-center justify-center h-100">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">No hay archivos seleccionados para procesar.</MudText>
                    </div>
                }
                else
                {
                    @foreach (var file in GetSelectedFiles())
                    {
                        <div class="file-card">
                            <div class="file-card-info">
                                <MudIcon Icon="@Icons.Custom.FileFormats.FileExcel" Size="Size.Medium" Color="Color.Success" />
                                <div class="file-card-text">
                                    <MudText Typo="Typo.body2" Class="file-name">@file.Name</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="file-path">@file.Path</MudText>
                                </div>
                            </div>
                            <MudIconButton Icon="@Icons.Material.Filled.RemoveCircleOutline" Color="Color.Error" Size="Size.Small" OnClick="@(() => RemoveFile(file))" />
                        </div>
                    }
                }
            </div>
            <div class="panel-footer">
                <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick="Cancelar" Class="footer-btn">Limpiar Todo</MudButton>
                @if (logsProcesamiento.Any())
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Info" OnClick="ExportarLog" StartIcon="@Icons.Material.Filled.Description" Class="footer-btn mx-2">
                        Exportar Log
                    </MudButton>
                }
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ProcesarSeleccion" Disabled="@(!GetSelectedFiles().Any())" Class="footer-btn confirm-btn px-8">
                    Iniciar
                </MudButton>
            </div>
        </div>
    </div>

    @if (procesando)
{
    <MudItem xs="12" Class="mt-4">
        <MudCard Elevation="1" Style="border: 1px solid #DAE0E6;">
            <MudCardHeader Style="background-color: #F8F9FA; border-bottom: 1px solid #DAE0E6;">
                <CardHeaderContent>
                    <MudText Typo="Typo.h6" Style="color: #002C54; font-weight: 700;">PROCESANDO ARCHIVOS</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent Class="pa-4">
                <MudProgressLinear Color="Color.Primary" Size="Size.Large" Striped="true" Value="@GetProgressValue()" Min="0" Max="100" />
                <MudText Typo="Typo.body2" Class="mt-2" Style="color: #002C54;">
                    @GetProgressText()
                </MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
}

    @if (ExplorerState.Resultados.Any() || logsProcesamiento.Any())
    {
        <MudItem xs="12" Class="mt-6">
            <MudCard Elevation="1" Style="border: 1px solid #DAE0E6;">
                <MudCardHeader Style="background-color: #F8F9FA; border-bottom: 1px solid #DAE0E6;">
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Style="color: #002C54; font-weight: 700;">CONSOLIDADO DE EXTRACCIÓN</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudButton Color="Color.Primary" Variant="Variant.Text">Descargar</MudButton>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    <MudDataGrid Items="@ExplorerState.Resultados" Dense="true" Hover="true" Striped="true" FixedHeader="true" Height="450px" Class="results-grid">
                        <Columns>
                            <PropertyColumn Property="x => x.Empresa" Title="Empresa" />
                            <PropertyColumn Property="x => x.Cuenta" Title="Cuenta Contable" />
                            <PropertyColumn Property="x => x.Categoria" Title="Categoría" />
                            <PropertyColumn Property="x => x.Tipo" Title="Naturaleza" />
                            <PropertyColumn Property="x => x.Nota" Title="Nota Ref." />
                            <PropertyColumn Property="x => x.Valor" Title="Saldo Local" Format="N2">
                                <CellTemplate>
                                    <MudText Style="font-weight: 600; color: #002C54;">@context.Item.Valor.ToString("N2")</MudText>
                                </CellTemplate>
                            </PropertyColumn>
                        </Columns>
                    </MudDataGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }

    @if (logsProcesamiento.Any())
    {
        <MudItem xs="12" Class="mt-6">
            <MudCard Elevation="1" Style="border: 1px solid #DAE0E6;">
                <MudCardHeader Style="background-color: #F8F9FA; border-bottom: 1px solid #DAE0E6;">
                     <CardHeaderContent>
                         <MudText Typo="Typo.h6" Style="color: #002C54; font-weight: 700;">LOG DE PROCESAMIENTO</MudText>
                     </CardHeaderContent>
                 </MudCardHeader>
                <MudCardContent Class="pa-0">
                    <div class="log-container">
                        @foreach (var log in logsProcesamiento)
                        {
                            <div class="log-entry @GetLogCssClass(log.Estado)">
                                <span class="log-timestamp">[@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")]</span>
                                <span class="log-level">[@log.Estado]</span>
                                <span class="log-message">@log.Mensaje</span>
                            </div>
                        }
                    </div>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</div>

<style>
