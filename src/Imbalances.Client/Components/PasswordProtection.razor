@using Imbalances.Client.Services
@inject ExplorerStateService ExplorerState

@if (!IsUnlocked)
{
    <div class="password-gate">
        <div class="password-gate__title">@Title</div>
        <div class="password-gate__row">
            <input type="password"
                   class="password-gate__input"
                   @bind-value="@_password"
                   @bind-value:event="oninput"
                   @onkeydown="@OnKeyDown" />
            <button class="password-gate__button" @onclick="@Unlock">Aceptar</button>
        </div>
    </div>
}
else
{
    @ChildContent
}

@code {
    [Parameter]
    public string Title { get; set; } = "ACCESO RESTRINGIDO";

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string CorrectPassword { get; set; } = "Juanes";

    [Parameter]
    public EventCallback OnUnlocked { get; set; }

    private bool IsUnlocked => ExplorerState.PasswordUnlocked;
    private string _password = string.Empty;

    protected override void OnInitialized()
    {
        if (ExplorerState.PasswordUnlocked)
        {
            _ = OnUnlocked.InvokeAsync();
        }
    }

    private async Task Unlock()
    {
        if (_password == CorrectPassword)
        {
            ExplorerState.PasswordUnlocked = true;
            _password = string.Empty;
            await OnUnlocked.InvokeAsync();
        }
        else
        {
            _password = string.Empty;
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            await Unlock();
        }
    }
}